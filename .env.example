# Copia este archivo a .env.local y rellena con los datos de TU proyecto Supabase.
# Ambas variables son publicas-seguras (la seguridad real la da RLS en la base de datos).
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU-ANON-KEY

# (Opcional) Numero del punto de ingesta SMS (SIM del gateway Android o numero Twilio).
# Si lo dejas vacio, /actualizar genera el SMS sin destinatario fijo.
NEXT_PUBLIC_SMS_INGEST_NUMBER=

# (Opcional) URL publica del sitio en produccion (ej. https://mi-app.vercel.app).
# Se usa como destino del magic-link de acceso. Debe COINCIDIR con las Redirect URLs
# configuradas en Supabase > Authentication > URL Configuration.
# Si la dejas vacia (modo local), el redirect cae a window.location.origin.
NEXT_PUBLIC_SITE_URL=
